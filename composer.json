{
    "name": "webconsulting/typo3-x402-paywall",
    "description": "x402 payment protocol for TYPO3 — charge AI agents and users for content access via HTTP 402.",
    "type": "typo3-cms-extension",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "typo3",
        "x402",
        "payment",
        "paywall",
        "micropayment",
        "ai-agent",
        "monetization",
        "stablecoin",
        "usdc"
    ],
    "authors": [
        {
            "name": "Kurt Dirnbauer",
            "email": "office@webconsulting.at",
            "homepage": "https://www.webconsulting.at",
            "role": "Lead Developer"
        }
    ],
    "homepage": "https://github.com/dirnbauer/typo3-x402-paywall",
    "support": {
        "issues": "https://github.com/dirnbauer/typo3-x402-paywall/issues",
        "source": "https://github.com/dirnbauer/typo3-x402-paywall"
    },
    "require": {
        "php": "^8.2",
        "typo3/cms-core": "^13.4 || ^14.0",
        "typo3/cms-frontend": "^13.4 || ^14.0",
        "guzzlehttp/guzzle": "^7.0",
        "mcp/sdk": "^0.5",
        "psr/http-message": "^2.0",
        "psr/http-server-middleware": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Webconsulting\\X402Paywall\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webconsulting\\X402Paywall\\Tests\\": "tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "x402_paywall"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true
        }
    }
}
